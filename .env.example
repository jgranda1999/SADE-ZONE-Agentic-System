# Copy to ".env" for docker compose (cp .env.example .env) and fill in secrets.
# Do not commit .env. In AWS, inject the same variables via task definitions / Secrets Manager.

# Required for orchestration (OpenAI Agents SDK)
OPENAI_API_KEY=sk-replace-me

# Required for outbound POST of completed evaluations (full URL including path)
DECISION_RESULT_URL=https://your-platform.example.com/decision-result

# Optional: protect POST /decision-request (omit in open dev environments)
# SADE_INGEST_API_KEY=
# SADE_INGEST_API_KEYS=key1,key2
# SADE_INGEST_REVOKED_KEYS=

# Optional: disable writing results/api-integration/*.json
# SADE_PERSIST_RESULTS=0

# docker-compose.yml sets REDIS_URL=redis://redis:6379/0 for api/worker; override only if needed.
